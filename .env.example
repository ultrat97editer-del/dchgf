# Environment variables for deployment

# Backend API URL (default: http://localhost:3000)
# For production, use your deployment URL
VITE_BACKEND_URL=https://backend-locket.vercel.app

# Admin password for admin panel access
ADMIN_PASSWORD=admin123

# Payment Configuration (VietQR/VNP)
# Bank account number for receiving payments
BANK_ACCOUNT=1234567890

# Bank BIN code (970416 = Vietcombank)
# Common bank codes:
# 970416 = Vietcombank (CTG)
# 970407 = Vietinbank (CTJ)
# 970439 = Techcombank (TCB)
# 970449 = ACB
BANK_BIN=970416

# Firebase config (keep as is from firebase.ts)
# These are already in firebase.ts and don't need .env
