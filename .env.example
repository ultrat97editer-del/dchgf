# Environment variables for Locket with PayOS Payment Integration

# Frontend React App Configuration
VITE_BACKEND_URL=http://localhost:3000

# Payment Backend API Server (API Server runs separately on port 3001)
# Local development: http://localhost:3001
# Production: https://your-api-server.vercel.app
PAYMENT_BACKEND_URL=http://localhost:3001

# Node Environment
NODE_ENV=development

# Admin password for admin panel access
ADMIN_PASSWORD=admin123

# ========================================
# API Server Configuration (api/server)
# See api/.env.example for PayOS setup
# ========================================

# PayOS Credentials (set in api/.env, not here)
# PAYOS_CLIENT_ID=your-client-id
# PAYOS_API_KEY=your-api-key
# PAYOS_CHECKSUM_KEY=your-checksum-key
